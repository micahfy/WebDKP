<?xml version="1.0" encoding="UTF-8"?>
<Ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/  ..\..\FrameXML\UI.xsd" xmlns="http://www.blizzard.com/wow/ui/">
  <!-- ================================================
       TEMPLATES 
       =================================================-->
  <!-- Define a template for a bid row entry -->
  <Frame name="ADKP_DKPBidLineTemplate" virtual="true">
    <Size>
      <AbsDimension x="350" y="20" />
    </Size>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture name="$parentBackground">
          <Anchors>
            <Anchor point="TOPLEFT" />
            <Anchor point="BOTTOMRIGHT" />
          </Anchors>
          <Color r="1" g="1" b="1" a="1" />
        </Texture>
      </Layer>
      <Layer level="ARTWORK">
        <FontString name="$parentName" inherits="ChatFontNormal" text="asdf">
          <Anchors>
            <Anchor point="LEFT">
              <Offset>
                <AbsDimension x="2" y="0" />
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <FontString name="$parentBid" inherits="ChatFontNormal" text="asdf">
          <Anchors>
            <Anchor point="LEFT">
              <Offset>
                <AbsDimension x="145" y="0" />
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <FontString name="$parentDKP" inherits="ChatFontNormal" text="asdf">
          <Anchors>
            <Anchor point="LEFT">
              <Offset>
                <AbsDimension x="220" y="0" />
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
        <FontString name="$parentPost" inherits="ChatFontNormal" text="asdf">
          <Anchors>
            <Anchor point="LEFT">
              <Offset>
                <AbsDimension x="290" y="0" />
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <Scripts>
      <OnLoad>
        getglobal(this:GetName() .. "Background"):SetVertexColor(0, 0, 0, 0);
      </OnLoad>
      <OnEnter>
        ADKP_Bid_HandleMouseOver();
      </OnEnter>
      <OnLeave>
        ADKP_Bid_HandleMouseLeave();
      </OnLeave>
      <OnMouseDown>
        ADKP_Bid_SelectPlayerToggle();
      </OnMouseDown>
    </Scripts>
  </Frame>
  <!-- ================================================
       MAIN FRAME
       =================================================-->
  <Frame name="ADKP_BidFrame" toplevel="true" parent="UIParent" movable="true" hidden="true">
    <!-- EVENT HANDLERS FOR THE MASTER FRAME -->
    <Scripts>
      <OnShow>
        local mode = (ADKP_Options and ADKP_Options["AuctionMode"]) or "public";
        if ADKP_BidFrameAuctionPublic then ADKP_BidFrameAuctionPublic:SetChecked(mode ~= "anonymous") end
        if ADKP_BidFrameAuctionAnonymous then ADKP_BidFrameAuctionAnonymous:SetChecked(mode == "anonymous") end
        if ADKP_UpdateBidQueueWindow then ADKP_UpdateBidQueueWindow() end
      </OnShow>
      <OnHide>
        if ADKP_BidQueueWindow then ADKP_BidQueueWindow:Hide() end
      </OnHide>
      <OnMouseDown>
        this:StartMoving();
        getglobal("ADKP_BidFrameItem"):ClearFocus();
        getglobal("ADKP_BidFrameTime"):ClearFocus();
      </OnMouseDown>
      <OnMouseUp>
        this:StopMovingOrSizing();
      </OnMouseUp>
    </Scripts>
    <Size>
      <AbsDimension x="400" y="500" />
    </Size>
    <Anchors>
      <Anchor point="LEFT" />
    </Anchors>
    <Backdrop bgFile="Interface\TutorialFrame\TutorialFrameBackground" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
      <EdgeSize>
        <AbsValue val="16" />
      </EdgeSize>
      <TileSize>
        <AbsValue val="16" />
      </TileSize>
      <BackgroundInsets>
        <AbsInset left="5" right="5" top="5" bottom="5" />
      </BackgroundInsets>
    </Backdrop>
    <!-- HEADER / ADDON TITLE-->
    <Layers>
      <Layer level="ARTWORK">
        <Texture name="$parentHeaderTexture" file="Interface\DialogFrame\UI-DialogBox-Header">
          <Size>
            <AbsDimension x="300" y="64" />
          </Size>
          <Anchors>
            <Anchor point="TOP">
              <Offset>
                <AbsDimension x="0" y="20" />
              </Offset>
            </Anchor>
          </Anchors>
        </Texture>
        <FontString name="$parentTitle" inherits="GameFontNormal" text="ADKP 竞拍系统">
          <Anchors>
            <Anchor point="TOP" relativeTo="$parentHeaderTexture">
              <Offset>
                <AbsDimension x="0" y="-14" />
              </Offset>
            </Anchor>
          </Anchors>
        </FontString>
      </Layer>
    </Layers>
    <!-- FRAMES (contains all gui elements -->
    <Frames>
      <!-- ITEM BEING BID ON -->
      <EditBox name="$parentItem" inherits="ADKPEditBoxTemplate">
        <Size>
          <AbsDimension x="130" y="32" />
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="90" y="-33" />
            </Offset>
          </Anchor>
        </Anchors>
        <Layers>
          <Layer level="ARTWORK">
            <FontString inherits="GameFontNormal" text="物品:">
              <Anchors>
                <Anchor point="TOPLEFT">
                  <Offset>
                    <AbsDimension x="-75" y="-8" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
            getglobal(this:GetParent():GetName().."Item"):SetAutoFocus( false );
            this:SetBackdropColor(0, 0, 0, 0.6);
            this:SetBackdropBorderColor(0.5, 0.5, 0.5, 1);
          </OnLoad>
          <OnEscapePressed>
            getglobal(this:GetParent():GetName().."Item"):ClearFocus();
          </OnEscapePressed>
          <OnEnterPressed>
            getglobal(this:GetParent():GetName().."Item"):ClearFocus();
          </OnEnterPressed>
        </Scripts>
      </EditBox>
      <!-- 拍卖模式切换（公开/匿名） -->
      <CheckButton name="ADKP_BidFrameAuctionPublic" inherits="UICheckButtonTemplate">
        <Size>
          <AbsDimension x="20" y="20" />
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="230" y="-33" />
            </Offset>
          </Anchor>
        </Anchors>
        <Layers>
          <Layer level="ARTWORK">
            <FontString inherits="GameFontNormalSmall" text="公开">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="25" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>
            ADKP_SelectAuctionMode("public");
          </OnClick>
        </Scripts>
      </CheckButton>
      <CheckButton name="ADKP_BidFrameAuctionAnonymous" inherits="UICheckButtonTemplate">
        <Size>
          <AbsDimension x="20" y="20" />
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="295" y="-33" />
            </Offset>
          </Anchor>
        </Anchors>
        <Layers>
          <Layer level="ARTWORK">
            <FontString inherits="GameFontNormalSmall" text="匿名">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="25" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>
            ADKP_SelectAuctionMode("anonymous");
          </OnClick>
        </Scripts>
      </CheckButton>
      <!-- BID TIME LIMIT -->
      <EditBox name="$parentTime" inherits="ADKPEditBoxTemplate">
        <Size>
          <AbsDimension x="65" y="32" />
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT" relativeTo="$parentItem" relativePoint="BOTTOMLEFT">
            <Offset>
              <AbsDimension x="0" y="-5" />
            </Offset>
          </Anchor>
        </Anchors>
        <Layers>
          <Layer level="ARTWORK">
            <FontString inherits="GameFontNormal" text="竞拍时间:">
              <Anchors>
                <Anchor point="TOPLEFT">
                  <Offset>
                    <AbsDimension x="-75" y="-10" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
            <FontString inherits="GameFontNormal" text="(单位:秒 - 使用0则不限时间)">
              <Anchors>
                <Anchor point="TOPLEFT">
                  <Offset>
                    <AbsDimension x="80" y="-10" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnLoad>
            getglobal(this:GetParent():GetName().."Time"):SetAutoFocus( false );
            this:SetBackdropColor(0, 0, 0, 0.6);
            this:SetBackdropBorderColor(0.5, 0.5, 0.5, 1);
          </OnLoad>
          <OnEscapePressed>
            getglobal(this:GetParent():GetName().."Time"):ClearFocus();
          </OnEscapePressed>
          <OnEnterPressed>
            getglobal(this:GetParent():GetName().."Time"):ClearFocus();
          </OnEnterPressed>
        </Scripts>
      </EditBox>
      <!-- START / STOP BIDDING BUTTON-->
      <Button name="$parentBidButton" inherits="OptionsButtonTemplate" text="开始竞拍!">
        <Anchors>
          <Anchor point="TOP" relativePoint="TOP">
            <Offset>
              <AbsDimension x="-60" y="-110" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="150" y="25" />
        </Size>
        <Scripts>
          <OnClick>
            ADKP_Bid_ButtonHandler();
          </OnClick>
        </Scripts>
      </Button>
      <!-- Manual countdown trigger -->
      <Button name="$parentManualCountdownButton" inherits="OptionsButtonTemplate" text="手动倒计时">
        <Anchors>
          <Anchor point="LEFT" relativeTo="$parentBidButton" relativePoint="RIGHT">
            <Offset>
              <AbsDimension x="10" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="110" y="25" />
        </Size>
        <Scripts>
          <OnClick>
            ADKP_ManualCountdown_Toggle();
          </OnClick>
        </Scripts>
      </Button>
      <!-- DKP TABLE COLUMN NAMES -->
      <Button name="$parentName" inherits="ADKP_LogTabTemplate">
        <Anchors>
          <Anchor point="TOPLEFT">
            <Offset>
              <AbsDimension x="16" y="-160" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="140" y="24" />
        </Size>
        <Layers>
          <Layer level="OVERLAY">
            <FontString inherits="GameFontNormal" text="名字">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="8" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
          <Layer level="ARTWORK">
            <FontString inherits="GameFontNormal" text="需求竞拍列表:">
              <Anchors>
                <Anchor point="TOPLEFT">
                  <Offset>
                    <AbsDimension x="0" y="20" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>ADKP_Bid_SortBy(1);</OnClick>
        </Scripts>
      </Button>
      <Button name="$parentBid" inherits="ADKP_LogTabTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="TOPRIGHT" relativeTo="$parentName">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="70" y="24" />
        </Size>
        <Layers>
          <Layer level="OVERLAY">
            <FontString inherits="GameFontNormal" text="出分">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="8" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>ADKP_Bid_SortBy(2);</OnClick>
        </Scripts>
      </Button>
      <Button name="$parentDKP" inherits="ADKP_LogTabTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="TOPRIGHT" relativeTo="$parentBid">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="70" y="24" />
        </Size>
        <Layers>
          <Layer level="OVERLAY">
            <FontString inherits="GameFontNormal" text="DKP">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="8" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>ADKP_Bid_SortBy(3);</OnClick>
        </Scripts>
      </Button>
      <Button name="$parentPost" inherits="ADKP_LogTabTemplate">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="TOPRIGHT" relativeTo="$parentDKP">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="70" y="24" />
        </Size>
        <Layers>
          <Layer level="OVERLAY">
            <FontString inherits="GameFontNormal" text="出分后剩余DKP">
              <Anchors>
                <Anchor point="LEFT">
                  <Offset>
                    <AbsDimension x="8" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
            <FontString inherits="GameFontNormal" text="" name="ADKP_BidFrame_Countdown">
              <Anchors>
                <Anchor point="TOPRIGHT">
                  <Offset>
                    <AbsDimension x="0" y="20" />
                  </Offset>
                </Anchor>
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
        <Scripts>
          <OnClick>ADKP_Bid_SortBy(4);</OnClick>
        </Scripts>
      </Button>
      <!-- DKP TABLE SCROLL FRAME -->
      <ScrollFrame name="$parentScrollFrame" inherits="FauxScrollFrameTemplate" hidden="false">
        <Size>
          <AbsDimension x="350" y="260" />
        </Size>
        <Anchors>
          <Anchor point="TOPLEFT" relativeTo="$parentName" relativePoint="bottomLeft">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnVerticalScroll>
            FauxScrollFrame_OnVerticalScroll(20, ADKP_Bid_UpdateTable);
          </OnVerticalScroll>
          <OnShow>
            ADKP_Bid_UpdateTable()
          </OnShow>
        </Scripts>
        <Layers>
          <Layer level="BACKGROUND">
            <Texture name="$parentBackground" setAllPoints="true">
              <Color r=".2" g=".2" b=".2" a="0.5" />
            </Texture>
          </Layer>
        </Layers>
      </ScrollFrame>
      <!-- DKP TABLE LINE ENTRIES -->
      <Frame name="$parentLine1" inherits="ADKP_DKPBidLineTemplate" id="1">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentName">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
      </Frame>
      <Frame name="$parentLine2" inherits="ADKP_DKPBidLineTemplate" id="2">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine1" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine3" inherits="ADKP_DKPBidLineTemplate" id="3">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine2" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine4" inherits="ADKP_DKPBidLineTemplate" id="4">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine3" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine5" inherits="ADKP_DKPBidLineTemplate" id="5">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine4" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine6" inherits="ADKP_DKPBidLineTemplate" id="6">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine5" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine7" inherits="ADKP_DKPBidLineTemplate" id="7">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine6" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine8" inherits="ADKP_DKPBidLineTemplate" id="8">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine7" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine9" inherits="ADKP_DKPBidLineTemplate" id="9">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine8" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine10" inherits="ADKP_DKPBidLineTemplate" id="10">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine9" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine11" inherits="ADKP_DKPBidLineTemplate" id="11">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine10" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine12" inherits="ADKP_DKPBidLineTemplate" id="12">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine11" />
        </Anchors>
      </Frame>
      <Frame name="$parentLine13" inherits="ADKP_DKPBidLineTemplate" id="13">
        <Anchors>
          <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT" relativeTo="$parentLine12" />
        </Anchors>
      </Frame>
      <!-- Close Button -->
      <Button name="$parentCloseButton" hidden="false">
        <Size>
          <AbsDimension x="42" y="42" />
        </Size>
        <Anchors>
          <Anchor point="TOPRIGHT">
            <Offset>
              <AbsDimension x="-5" y="-5" />
            </Offset>
          </Anchor>
        </Anchors>
        <Scripts>
          <OnClick>
            HideUIPanel(this:GetParent());
          </OnClick>
        </Scripts>
        <NormalTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Up" />
        <PushedTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Down" />
        <HighlightTexture file="Interface\Buttons\UI-Panel-MinimizeButton-Highlight" alphaMode="ADD" />
      </Button>
      <Button name="$parentAward" inherits="OptionsButtonTemplate" text="授予物品给玩家">
        <Anchors>
          <Anchor point="BOTTOM" relativePoint="BOTTOM" relativeTo="$parent">
            <Offset>
              <AbsDimension x="80" y="10" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="150" y="25" />
        </Size>
        <Scripts>
          <OnClick>
            ADKP_Bid_AwardSelected();
          </OnClick>
        </Scripts>
      </Button>
      <Button name="$parentAnnounceHighButton" inherits="OptionsButtonTemplate" text="宣告当前最高值">
        <Anchors>
          <Anchor point="RIGHT" relativePoint="LEFT" relativeTo="$parentAward">
            <Offset>
              <AbsDimension x="-10" y="0" />
            </Offset>
          </Anchor>
        </Anchors>
        <Size>
          <AbsDimension x="150" y="25" />
        </Size>
        <Scripts>
          <OnClick>
            ADKP_Bid_AnnounceSelected();
          </OnClick>
        </Scripts>
      </Button>
    </Frames>
  </Frame>
  <!-- ================================================
       UPDATE / TIMER FRAME
       =================================================-->
  <Frame name="ADKP_Bid_UpdateFrame" toplevel="true" parent="UIParent" hidden="true">
    <Scripts>
      <OnLoad>this.TimeSinceLastUpdate = 0 </OnLoad>
      <OnUpdate>ADKP_Bid_OnUpdate(arg1);</OnUpdate>
    </Scripts>
  </Frame>
</Ui>
